---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import TableOfContents from '../components/TableOfContents.astro';
import AuthorBio from '../components/AuthorBio.astro';
import RelatedReading from '../components/RelatedReading.astro';
import { site } from '../data/site';
import { relatedArticles, type Article } from '../data/articles';

export interface Heading { id: string; text: string; }
export interface Props {
  article: Article;
  headings: Heading[];
}
const { article, headings } = Astro.props;
const related = relatedArticles(article, 3);

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: article.title,
  description: article.excerpt,
  image: new URL(article.hero, Astro.site).toString(),
  datePublished: article.publishDate,
  dateModified: article.updateDate || article.publishDate,
  author: {
    '@type': 'Person',
    name: site.author.name,
    jobTitle: site.author.role,
    url: new URL('/redaktionen/', Astro.site).toString(),
  },
  publisher: {
    '@type': 'Organization',
    name: site.name,
    url: site.url,
  },
  mainEntityOfPage: { '@type': 'WebPage', '@id': new URL(article.url, Astro.site).toString() },
};
---
<BaseLayout
  title={`${article.title} | ${site.name}`}
  description={article.excerpt}
  ogImage={article.hero}
  schema={schema}
>
  <article class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 md:py-14">
    <Breadcrumbs crumbs={[{ label: article.categoryLabel, url: article.categoryUrl }, { label: article.title }]} />

    <header class="max-w-3xl mb-8">
      <div class="flex flex-wrap items-center gap-3 mb-5">
        <a href={article.categoryUrl} class="label text-[var(--color-accent)] hover:text-[var(--color-text)]">{article.categoryLabel}</a>
        <span class="text-[var(--color-text-dim)] mono text-xs">·</span>
        <time class="mono text-xs text-[var(--color-text-lighter)]" datetime={article.publishDate}>{article.publishDate}</time>
        <span class="text-[var(--color-text-dim)] mono text-xs">·</span>
        <span class="mono text-xs text-[var(--color-text-lighter)]">{article.readingTime} min läsning</span>
      </div>
      <h1 class="display text-3xl sm:text-4xl md:text-5xl mb-5">{article.title}</h1>
      <p class="text-lg text-[var(--color-text-light)] leading-relaxed">{article.excerpt}</p>
    </header>

    <figure class="mb-10 -mx-4 sm:mx-0">
      <img src={article.hero} alt={article.heroAlt} width="1600" height="900" fetchpriority="high" loading="eager" class="w-full aspect-[16/9] object-cover sm:rounded-xl border-y sm:border border-[var(--color-border)]" />
    </figure>

    <div class="grid grid-cols-1 lg:grid-cols-[1fr_280px] gap-12">
      <div class="prose-article">
        <slot />
        <AuthorBio />
      </div>

      <aside class="hidden lg:block">
        <div class="sticky top-24">
          <TableOfContents headings={headings} />
          <div class="mt-6 p-5 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-card)]">
            <div class="label mb-2">Skribent</div>
            <div class="flex items-center gap-3">
              <img src={site.author.image} alt="" width="40" height="40" loading="lazy" class="rounded-full w-10 h-10 object-cover border border-[var(--color-border-bright)]" />
              <div>
                <div class="font-medium text-sm">{site.author.name}</div>
                <div class="text-xs text-[var(--color-text-lighter)]">{site.author.short}</div>
              </div>
            </div>
          </div>
        </div>
      </aside>
    </div>

    <RelatedReading items={related} />
  </article>
</BaseLayout>
