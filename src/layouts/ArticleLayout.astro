---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import TableOfContents from '../components/TableOfContents.astro';
import AuthorBio from '../components/AuthorBio.astro';
import RelatedReading from '../components/RelatedReading.astro';
import { site } from '../data/site';
import { relatedArticles, type Article } from '../data/articles';
import { formatDate } from '../lib/date';

export interface Heading { id: string; text: string; }
export interface Props {
  article: Article;
  headings: Heading[];
}
const { article, headings } = Astro.props;
const related = relatedArticles(article, 3);

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: article.title,
  description: article.excerpt,
  image: new URL(article.hero, Astro.site).toString(),
  datePublished: article.publishDate,
  dateModified: article.updateDate || article.publishDate,
  author: {
    '@type': 'Person',
    name: site.author.name,
    jobTitle: site.author.role,
    url: new URL('/redaktionen/adrian-hellstrom/', Astro.site).toString(),
  },
  publisher: {
    '@type': 'Organization',
    name: site.name,
    url: site.url,
    logo: {
      '@type': 'ImageObject',
      url: new URL('/favicon.svg', Astro.site).toString(),
    },
  },
  mainEntityOfPage: { '@type': 'WebPage', '@id': new URL(article.url, Astro.site).toString() },
};
---
<BaseLayout
  title={`${article.title} | ${site.name}`}
  description={article.excerpt}
  ogImage={article.hero}
  schema={schema}
>
  <article class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 md:py-14">
    <Breadcrumbs crumbs={[{ label: article.categoryLabel, url: article.categoryUrl }, { label: article.title }]} />

    <header class="max-w-3xl mb-8">
      <div class="flex flex-wrap items-center gap-3 mb-5">
        <a href={article.categoryUrl} class="label text-[var(--color-accent)] hover:text-[var(--color-text)] transition-colors">{article.categoryLabel}</a>
        {article.cornerstone && (
          <>
            <span class="text-[var(--color-text-dim)] mono text-xs">·</span>
            <span class="label text-[var(--color-violet)]">Cornerstone</span>
          </>
        )}
      </div>
      <h1 class="display text-3xl sm:text-4xl md:text-5xl mb-5">{article.title}</h1>
      <p class="text-lg text-[var(--color-text-light)] leading-relaxed mb-6">{article.excerpt}</p>

      <div class="flex flex-wrap items-center gap-4 pt-4 border-t border-[var(--color-border)]">
        <a href="/redaktionen/adrian-hellstrom/" class="flex items-center gap-3 group">
          <img src={site.author.image} alt="" width="36" height="36" loading="lazy" class="rounded-full w-9 h-9 object-cover border border-[var(--color-border-bright)]" />
          <div class="leading-tight">
            <div class="text-sm font-medium text-[var(--color-text)] group-hover:text-[var(--color-accent)] transition-colors">{site.author.name}</div>
            <div class="mono text-[0.7rem] uppercase tracking-wider text-[var(--color-text-lighter)]">{site.author.role}</div>
          </div>
        </a>
        <span class="text-[var(--color-text-dim)] mono text-xs hidden sm:inline">·</span>
        <div class="flex items-center gap-3 text-xs mono text-[var(--color-text-lighter)]">
          <time datetime={article.publishDate}>Publicerad {formatDate(article.publishDate)}</time>
          {article.updateDate && article.updateDate !== article.publishDate && (
            <>
              <span class="text-[var(--color-text-dim)]">·</span>
              <time datetime={article.updateDate}>Uppdaterad {formatDate(article.updateDate)}</time>
            </>
          )}
          <span class="text-[var(--color-text-dim)]">·</span>
          <span>{article.readingTime} min läsning</span>
        </div>
      </div>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-[1fr_280px] gap-12 mt-10">
      <div class="prose-article">
        <slot />
        <AuthorBio />
      </div>

      <aside class="hidden lg:block">
        <div class="sticky top-24">
          <TableOfContents headings={headings} />

          <div class="mt-6 p-5 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-card)]">
            <div class="label mb-3">Skribent</div>
            <a href="/redaktionen/adrian-hellstrom/" class="flex items-center gap-3 group">
              <img src={site.author.image} alt="" width="40" height="40" loading="lazy" class="rounded-full w-10 h-10 object-cover border border-[var(--color-border-bright)]" />
              <div>
                <div class="font-medium text-sm group-hover:text-[var(--color-accent)] transition-colors">{site.author.name}</div>
                <div class="text-xs text-[var(--color-text-lighter)]">{site.author.short}</div>
              </div>
            </a>
          </div>

          <div class="mt-6 p-5 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-card)]">
            <div class="label mb-3">Faktagranskat</div>
            <p class="text-xs text-[var(--color-text-light)] leading-relaxed mb-3">Påståenden i denna artikel är granskade mot primärkällor. Hittar du ett fel? Mejla oss.</p>
            <a href="/metod/" class="text-xs mono text-[var(--color-accent)] hover:text-[var(--color-text)] transition-colors">Vår redaktionella metod →</a>
          </div>
        </div>
      </aside>
    </div>

    <RelatedReading items={related} />
  </article>
</BaseLayout>
