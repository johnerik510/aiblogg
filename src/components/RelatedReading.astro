---
import type { Article } from '../data/articles';
import { formatDate } from '../lib/date';
export interface Props { items: Article[]; title?: string; }
const { items, title = 'Mer från aiblogg' } = Astro.props;
---
{items.length > 0 && (
  <section class="mt-16 pt-12 border-t border-[var(--color-border)]">
    <h2 class="text-xl font-semibold tracking-tight mb-6">{title}</h2>
    <ol class="divide-y divide-[var(--color-border)] border-y border-[var(--color-border)]">
      {items.map(a => (
        <li class="group">
          <a href={a.url} class="grid grid-cols-1 sm:grid-cols-[1fr_140px] gap-2 sm:gap-6 items-baseline py-4 hover:bg-[var(--color-bg-card)] transition-colors px-2 -mx-2 rounded-md">
            <div class="min-w-0">
              <div class="flex flex-wrap items-center gap-x-3 mb-1">
                <span class="label text-[var(--color-accent)]">{a.categoryLabel}</span>
              </div>
              <h3 class="font-semibold text-base leading-snug tracking-tight text-[var(--color-text)] group-hover:text-[var(--color-accent)] transition-colors">{a.title}</h3>
            </div>
            <time class="mono text-xs text-[var(--color-text-lighter)] sm:text-right">{formatDate(a.publishDate)}</time>
          </a>
        </li>
      ))}
    </ol>
  </section>
)}
