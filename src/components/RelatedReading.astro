---
import type { Article } from '../data/articles';
export interface Props { items: Article[]; title?: string; }
const { items, title = 'Mer från aiblogg' } = Astro.props;
---
{items.length > 0 && (
  <section class="mt-16 pt-12 border-t border-[var(--color-border)]">
    <h2 class="text-xl font-semibold tracking-tight mb-6">{title}</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {items.map(a => (
        <article class="group rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-card)] overflow-hidden card-hover">
          <a href={a.url} aria-hidden="true" tabindex="-1" class="block aspect-[16/9] overflow-hidden bg-[var(--color-bg-elevated)]">
            <img src={a.hero} alt="" width="1600" height="900" loading="lazy" decoding="async" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
          </a>
          <div class="p-5">
            <div class="flex items-center gap-3 mb-2.5">
              <span class="label">{a.categoryLabel}</span>
            </div>
            <h3 class="font-semibold text-[1.05rem] leading-snug tracking-tight mb-2">
              <a href={a.url} class="text-[var(--color-text)] hover:text-[var(--color-accent)] transition-colors">{a.title}</a>
            </h3>
            <p class="text-sm text-[var(--color-text-light)] line-clamp-2 leading-relaxed">{a.excerpt}</p>
          </div>
        </article>
      ))}
    </div>
  </section>
)}
