---
const usps = [
  { icon: 'check', text: 'Oberoende redaktion' },
  { icon: 'sparkle', text: 'Hands-on testat' },
];
---
<div class="bg-[var(--color-bg-alt)] border-b border-[var(--color-border)] text-[var(--color-text-light)]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-2 flex items-center justify-center gap-6 sm:gap-10">
    {usps.map(u => (
      <div class="flex items-center gap-2 text-[0.72rem] sm:text-xs">
        {u.icon === 'check' ? (
          <svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--color-accent)] shrink-0">
            <circle cx="8" cy="8" r="6.5" />
            <path d="m5.5 8 1.8 1.8L10.5 6.5" />
          </svg>
        ) : (
          <svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-[var(--color-violet)] shrink-0">
            <path d="M8 1.5 9.3 6.7 14.5 8 9.3 9.3 8 14.5 6.7 9.3 1.5 8 6.7 6.7Z" />
          </svg>
        )}
        <span class="mono uppercase tracking-wider font-medium whitespace-nowrap">{u.text}</span>
      </div>
    ))}
  </div>
</div>
