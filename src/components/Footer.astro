---
import { clusters, recentArticles } from '../data/articles';
import { site } from '../data/site';
const year = new Date().getFullYear();
const recent = recentArticles(4);
---
<footer class="mt-24 border-t border-[var(--color-border)] bg-[var(--color-bg-alt)]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-14 pb-10">
    <div class="grid grid-cols-2 md:grid-cols-12 gap-8 mb-12">
      <div class="col-span-2 md:col-span-4">
        <div class="flex items-center gap-2 mb-4">
          <span class="relative">
            <span class="block w-7 h-7 rounded-md bg-gradient-to-br from-[var(--color-accent)] to-[var(--color-violet)]"></span>
            <span class="absolute inset-0 w-7 h-7 rounded-md bg-gradient-to-br from-[var(--color-accent)] to-[var(--color-violet)] blur-md opacity-40"></span>
          </span>
          <span class="font-semibold tracking-tight text-[1.05rem]">{site.name}</span>
        </div>
        <p class="text-sm text-[var(--color-text-light)] max-w-md mb-5 leading-relaxed">{site.description}</p>
        <p class="text-xs text-[var(--color-text-lighter)] mb-1">
          Redaktion: <!--email_off--><a href={`mailto:${site.contactEmail}`} class="hover:text-[var(--color-text)]">{site.contactEmail}</a><!--/email_off-->
        </p>
        <p class="text-xs text-[var(--color-text-lighter)]">
          Ansvarig utgivare: <a href="/redaktionen/adrian-hellstrom/" class="hover:text-[var(--color-text)]">{site.author.name}</a>
        </p>
      </div>

      <div class="md:col-span-3">
        <div class="label mb-4">Ämnen</div>
        <ul class="space-y-2.5 text-sm">
          {clusters.map(c => (
            <li><a href={c.url} class="text-[var(--color-text-light)] hover:text-[var(--color-accent)] transition-colors">{c.label}</a></li>
          ))}
        </ul>
      </div>

      <div class="md:col-span-3">
        <div class="label mb-4">Senaste artiklar</div>
        <ul class="space-y-3 text-sm">
          {recent.map(a => (
            <li>
              <a href={a.url} class="text-[var(--color-text-light)] hover:text-[var(--color-accent)] transition-colors block leading-snug">{a.title}</a>
            </li>
          ))}
        </ul>
      </div>

      <div class="md:col-span-2">
        <div class="label mb-4">Om sajten</div>
        <ul class="space-y-2.5 text-sm">
          <li><a href="/om/" class="text-[var(--color-text-light)] hover:text-[var(--color-accent)] transition-colors">Om oss</a></li>
          <li><a href="/metod/" class="text-[var(--color-text-light)] hover:text-[var(--color-accent)] transition-colors">Vår metod</a></li>
          <li><a href="/redaktionen/" class="text-[var(--color-text-light)] hover:text-[var(--color-accent)] transition-colors">Redaktionen</a></li>
          <li><a href="/redaktionell-policy/" class="text-[var(--color-text-light)] hover:text-[var(--color-accent)] transition-colors">Redaktionell policy</a></li>
          <li><a href="/sponsrat-innehall/" class="text-[var(--color-text-light)] hover:text-[var(--color-accent)] transition-colors">Sponsrat innehåll</a></li>
          <li><a href="/samarbeta/" class="text-[var(--color-text-light)] hover:text-[var(--color-accent)] transition-colors">Samarbeta</a></li>
          <li><a href="/kontakt/" class="text-[var(--color-text-light)] hover:text-[var(--color-accent)] transition-colors">Kontakt</a></li>
          <li><a href="/integritetspolicy/" class="text-[var(--color-text-light)] hover:text-[var(--color-accent)] transition-colors">Integritetspolicy</a></li>
          <li><a href="/cookies/" class="text-[var(--color-text-light)] hover:text-[var(--color-accent)] transition-colors">Cookies</a></li>
          <li><a href="/rss.xml" class="text-[var(--color-text-light)] hover:text-[var(--color-accent)] transition-colors">RSS-feed</a></li>
        </ul>
      </div>
    </div>

    <div class="pt-6 border-t border-[var(--color-border)] flex flex-col sm:flex-row justify-between gap-4 text-xs text-[var(--color-text-lighter)]">
      <div class="mono">© {year} {site.company.name} · Org.nr {site.company.orgNumber} · Oberoende redaktion.</div>
      <div class="mono">Hostat på Cloudflare Pages. Byggd med Astro.</div>
    </div>
  </div>
</footer>
