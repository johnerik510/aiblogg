---
import { clusters } from '../data/articles';
import { site } from '../data/site';
const year = new Date().getFullYear();
---
<footer class="mt-24 border-t border-[var(--color-border)] bg-[var(--color-bg-alt)]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
      <div class="col-span-2">
        <div class="flex items-center gap-2 mb-3">
          <span class="block w-6 h-6 rounded-md bg-gradient-to-br from-[var(--color-accent)] to-[var(--color-violet)]"></span>
          <span class="font-semibold tracking-tight">{site.name}</span>
        </div>
        <p class="text-sm text-[var(--color-text-light)] max-w-md mb-4 leading-relaxed">{site.description}</p>
        <p class="text-xs text-[var(--color-text-lighter)]">
          Kontakt: <!--email_off--><a href={`mailto:${site.contactEmail}`} class="hover:text-[var(--color-text)]">{site.contactEmail}</a><!--/email_off-->
        </p>
      </div>

      <div>
        <div class="label mb-3">Kategorier</div>
        <ul class="space-y-2 text-sm">
          {clusters.map(c => (
            <li><a href={c.url} class="text-[var(--color-text-light)] hover:text-[var(--color-text)]">{c.label}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <div class="label mb-3">Om sajten</div>
        <ul class="space-y-2 text-sm">
          <li><a href="/om/" class="text-[var(--color-text-light)] hover:text-[var(--color-text)]">Om aiblogg.se</a></li>
          <li><a href="/redaktionen/" class="text-[var(--color-text-light)] hover:text-[var(--color-text)]">Redaktionen</a></li>
          <li><a href="/redaktionell-policy/" class="text-[var(--color-text-light)] hover:text-[var(--color-text)]">Redaktionell policy</a></li>
          <li><a href="/sponsrat-innehall/" class="text-[var(--color-text-light)] hover:text-[var(--color-text)]">Sponsrat innehåll</a></li>
          <li><a href="/samarbeta/" class="text-[var(--color-text-light)] hover:text-[var(--color-text)]">Samarbeta</a></li>
          <li><a href="/kontakt/" class="text-[var(--color-text-light)] hover:text-[var(--color-text)]">Kontakt</a></li>
          <li><a href="/integritetspolicy/" class="text-[var(--color-text-light)] hover:text-[var(--color-text)]">Integritetspolicy</a></li>
          <li><a href="/cookies/" class="text-[var(--color-text-light)] hover:text-[var(--color-text)]">Cookies</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-10 pt-6 border-t border-[var(--color-border)] flex flex-col sm:flex-row justify-between gap-4 text-xs text-[var(--color-text-lighter)]">
      <div class="mono">© {year} {site.name}. Oberoende redaktion.</div>
      <div class="mono">Hostat på Cloudflare Pages</div>
    </div>
  </div>
</footer>
