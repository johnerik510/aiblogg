---
export interface Props {
  src: string;
  alt: string;
  caption?: string;
  width?: number;
  height?: number;
}
const { src, alt, caption, width = 1200, height = 675 } = Astro.props;
---
<figure class="my-8">
  <img src={src} alt={alt} width={width} height={height} loading="lazy" decoding="async" class="w-full rounded-lg border border-[var(--color-border)]" />
  {caption && <figcaption class="mt-2 text-center text-xs mono text-[var(--color-text-lighter)]">{caption}</figcaption>}
</figure>
