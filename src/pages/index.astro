---
import BaseLayout from '../layouts/BaseLayout.astro';
import { clusters, recentArticles, articlesByCluster } from '../data/articles';
import { site } from '../data/site';
import { formatDate } from '../lib/date';

// Auto-uppdaterande: alltid de senast publicerade
const latest = recentArticles(12);
---
<BaseLayout
  title={`${site.name}, ${site.tagline}`}
  description={site.description}
>
  <!-- Hero (textbaserad, ingen bild) -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-10 md:pt-16 pb-10">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-6">
      <div>
        <div class="label mb-3 flex items-center gap-2">
          <span class="inline-block w-1.5 h-1.5 rounded-full bg-[var(--color-accent)] shadow-[0_0_8px_var(--color-accent)]"></span>
          AI på svenska
        </div>
        <h1 class="display text-4xl sm:text-5xl md:text-6xl max-w-3xl">
          AI utan <span class="gradient-text">hype</span>.<br/>
          Verktyg, guider och analys.
        </h1>
      </div>
      <p class="text-[var(--color-text-light)] max-w-md text-base leading-relaxed">Oberoende redaktion. Tekniskt grundade jämförelser av verktyg, praktiska guider och nyktra analyser av AI-utvecklingen i Sverige.</p>
    </div>
  </section>

  <!-- Senaste artiklarna, högst upp, auto-uppdaterande -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 border-t border-[var(--color-border)]">
    <div class="flex items-end justify-between mb-8">
      <div>
        <div class="label mb-2 flex items-center gap-2">
          <span class="inline-block w-1.5 h-1.5 rounded-full bg-[var(--color-accent)]"></span>
          Senaste
        </div>
        <h2 class="text-2xl md:text-3xl font-semibold tracking-tight">Nyligen publicerat</h2>
      </div>
    </div>

    <ol class="divide-y divide-[var(--color-border)] border-y border-[var(--color-border)]">
      {latest.map((a, i) => (
        <li class="group">
          <a href={a.url} class="grid grid-cols-[40px_1fr_auto] sm:grid-cols-[60px_1fr_180px] gap-4 sm:gap-8 items-baseline py-5 hover:bg-[var(--color-bg-card)] transition-colors px-2 -mx-2 rounded-md">
            <span class="mono text-sm text-[var(--color-text-dim)] tabular-nums pt-0.5">{String(i + 1).padStart(2, '0')}</span>
            <div class="min-w-0">
              <div class="flex flex-wrap items-center gap-x-3 gap-y-1 mb-1.5">
                <span class="label text-[var(--color-accent)]">{a.categoryLabel}</span>
                {a.cornerstone && (
                  <>
                    <span class="mono text-xs text-[var(--color-text-dim)]">·</span>
                    <span class="label text-[var(--color-violet)]">Cornerstone</span>
                  </>
                )}
                <span class="mono text-xs text-[var(--color-text-dim)] sm:hidden">·</span>
                <time class="mono text-xs text-[var(--color-text-lighter)] sm:hidden">{formatDate(a.publishDate)}</time>
              </div>
              <h3 class="font-semibold text-lg md:text-xl leading-snug tracking-tight text-[var(--color-text)] group-hover:text-[var(--color-accent)] transition-colors mb-1">{a.title}</h3>
              <p class="text-sm text-[var(--color-text-light)] leading-relaxed line-clamp-2 sm:line-clamp-1">{a.excerpt}</p>
            </div>
            <div class="hidden sm:block text-right">
              <time class="mono text-xs text-[var(--color-text-lighter)] block">{formatDate(a.publishDate)}</time>
              <span class="mono text-xs text-[var(--color-text-dim)] block mt-0.5">{a.readingTime} min läsning</span>
            </div>
          </a>
        </li>
      ))}
    </ol>
  </section>

  <!-- Kategorier -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 border-t border-[var(--color-border)]">
    <div class="flex items-end justify-between mb-8">
      <div>
        <div class="label mb-2">Bläddra efter ämne</div>
        <h2 class="text-2xl md:text-3xl font-semibold tracking-tight">Kategorier</h2>
      </div>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {clusters.map(c => {
        const count = articlesByCluster(c.slug).length;
        const isViolet = c.accent === 'violet';
        return (
          <a href={c.url} class="group rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-card)] p-6 card-hover block">
            <div class="flex items-center justify-between mb-3">
              <span class={`inline-flex items-center justify-center w-8 h-8 rounded-md ${isViolet ? 'bg-[rgba(139,92,246,0.15)] text-[var(--color-violet)]' : 'bg-[rgba(0,229,255,0.12)] text-[var(--color-accent)]'}`}>
                <span class="text-xs mono">{c.shortLabel.charAt(0)}</span>
              </span>
              <span class="mono text-xs text-[var(--color-text-dim)]">{String(count).padStart(2,'0')} artiklar</span>
            </div>
            <h3 class="font-semibold text-lg tracking-tight mb-2 group-hover:text-[var(--color-accent)] transition-colors">{c.label}</h3>
            <p class="text-sm text-[var(--color-text-light)] leading-relaxed">{c.description}</p>
          </a>
        );
      })}
    </div>
  </section>

  <!-- Editor / E-E-A-T-signal -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 border-t border-[var(--color-border)]">
    <div class="grid grid-cols-1 md:grid-cols-[200px_1fr] gap-8 items-start max-w-4xl">
      <img src={site.author.image} alt={`Porträtt av ${site.author.name}`} width="200" height="200" loading="lazy" class="rounded-xl w-full max-w-[200px] aspect-square object-cover border border-[var(--color-border)]" />
      <div>
        <div class="label mb-2">Bakom redaktionen</div>
        <h2 class="text-2xl md:text-3xl font-semibold tracking-tight mb-2">{site.author.name}</h2>
        <div class="text-[var(--color-text-lighter)] mb-4 mono text-sm">{site.author.role}</div>
        <p class="text-[var(--color-text-light)] leading-relaxed mb-5">{site.author.bio}</p>
        <a href="/redaktionen/adrian-hellstrom/" class="inline-flex items-center gap-2 text-sm text-[var(--color-accent)] hover:text-[var(--color-text)] transition-colors">
          Hela skribentsidan <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
