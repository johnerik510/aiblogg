---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { clusters, articlesByCluster } from '../../data/articles';
import { site } from '../../data/site';
import { formatDate } from '../../lib/date';

export function getStaticPaths() {
  return clusters.map(c => ({ params: { category: c.slug }, props: { cluster: c } }));
}

const { cluster } = Astro.props;
const all = articlesByCluster(cluster.slug).sort((a, b) => b.publishDate.localeCompare(a.publishDate));
const cornerstones = all.filter(a => a.cornerstone);
const others = all.filter(a => !a.cornerstone);

const isViolet = cluster.accent === 'violet';
---
<BaseLayout
  title={`${cluster.label}, ${site.name}`}
  description={cluster.description}
>
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-10 pb-12">
    <Breadcrumbs crumbs={[{ label: cluster.label }]} />

    <div class="grid grid-cols-1 md:grid-cols-12 gap-10 mb-12 items-start">
      <div class="md:col-span-7">
        <div class="flex items-center gap-3 mb-4">
          <span class={`inline-flex items-center justify-center w-9 h-9 rounded-md ${isViolet ? 'bg-[rgba(139,92,246,0.18)] text-[var(--color-violet)]' : 'bg-[rgba(0,229,255,0.15)] text-[var(--color-accent)]'}`}>
            <span class="text-sm mono font-semibold">{cluster.shortLabel.charAt(0)}</span>
          </span>
          <div class="label">Kategori</div>
        </div>
        <h1 class="display text-4xl md:text-5xl mb-5">{cluster.label}</h1>
        <p class="text-lg text-[var(--color-text-light)] leading-relaxed">{cluster.intro}</p>
      </div>

      <aside class="md:col-span-5 md:pt-12">
        <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-card)] p-5">
          <div class="label mb-3">Översikt</div>
          <div class="grid grid-cols-3 gap-4 text-sm">
            <div>
              <div class="mono text-2xl font-semibold text-[var(--color-text)]">{all.length}</div>
              <div class="text-xs text-[var(--color-text-lighter)] mt-0.5">Artiklar</div>
            </div>
            <div>
              <div class="mono text-2xl font-semibold text-[var(--color-accent)]">{cornerstones.length}</div>
              <div class="text-xs text-[var(--color-text-lighter)] mt-0.5">Cornerstones</div>
            </div>
            <div>
              <div class="mono text-2xl font-semibold text-[var(--color-text)]">{Math.round(all.reduce((s, a) => s + a.readingTime, 0))}<span class="text-base text-[var(--color-text-lighter)]"> min</span></div>
              <div class="text-xs text-[var(--color-text-lighter)] mt-0.5">Total läsning</div>
            </div>
          </div>
        </div>
      </aside>
    </div>

    {cornerstones.length > 0 && (
      <section class="mb-12">
        <div class="label mb-5">Börja här, cornerstone-guider</div>
        <ol class="divide-y divide-[var(--color-border)] border-y border-[var(--color-border)]">
          {cornerstones.map((a, i) => (
            <li class="group">
              <a href={a.url} class="grid grid-cols-[40px_1fr_auto] sm:grid-cols-[60px_1fr_180px] gap-4 sm:gap-8 items-baseline py-5 hover:bg-[var(--color-bg-card)] transition-colors px-2 -mx-2 rounded-md">
                <span class="mono text-sm text-[var(--color-violet)] tabular-nums pt-0.5">{String(i + 1).padStart(2, '0')}</span>
                <div class="min-w-0">
                  <div class="flex flex-wrap items-center gap-x-3 mb-1.5">
                    <span class="label text-[var(--color-violet)]">Cornerstone</span>
                    <span class="mono text-xs text-[var(--color-text-dim)] sm:hidden">·</span>
                    <time class="mono text-xs text-[var(--color-text-lighter)] sm:hidden">{formatDate(a.publishDate)}</time>
                  </div>
                  <h2 class="font-semibold text-lg md:text-xl leading-snug tracking-tight text-[var(--color-text)] group-hover:text-[var(--color-accent)] transition-colors mb-1">{a.title}</h2>
                  <p class="text-sm text-[var(--color-text-light)] leading-relaxed line-clamp-2 sm:line-clamp-1">{a.excerpt}</p>
                </div>
                <div class="hidden sm:block text-right">
                  <time class="mono text-xs text-[var(--color-text-lighter)] block">{formatDate(a.publishDate)}</time>
                  <span class="mono text-xs text-[var(--color-text-dim)] block mt-0.5">{a.readingTime} min läsning</span>
                </div>
              </a>
            </li>
          ))}
        </ol>
      </section>
    )}

    <section>
      <div class="label mb-5">{cornerstones.length > 0 ? `Fler artiklar i ${cluster.shortLabel.toLowerCase()}` : `Alla artiklar i ${cluster.shortLabel.toLowerCase()}`}</div>
      <ol class="divide-y divide-[var(--color-border)] border-y border-[var(--color-border)]">
        {(cornerstones.length > 0 ? others : all).map((a, i) => (
          <li class="group">
            <a href={a.url} class="grid grid-cols-[40px_1fr_auto] sm:grid-cols-[60px_1fr_180px] gap-4 sm:gap-8 items-baseline py-5 hover:bg-[var(--color-bg-card)] transition-colors px-2 -mx-2 rounded-md">
              <span class="mono text-sm text-[var(--color-text-dim)] tabular-nums pt-0.5">{String(i + 1).padStart(2, '0')}</span>
              <div class="min-w-0">
                <div class="flex flex-wrap items-center gap-x-3 mb-1.5 sm:hidden">
                  <time class="mono text-xs text-[var(--color-text-lighter)]">{formatDate(a.publishDate)}</time>
                </div>
                <h2 class="font-semibold text-lg md:text-xl leading-snug tracking-tight text-[var(--color-text)] group-hover:text-[var(--color-accent)] transition-colors mb-1">{a.title}</h2>
                <p class="text-sm text-[var(--color-text-light)] leading-relaxed line-clamp-2 sm:line-clamp-1">{a.excerpt}</p>
              </div>
              <div class="hidden sm:block text-right">
                <time class="mono text-xs text-[var(--color-text-lighter)] block">{formatDate(a.publishDate)}</time>
                <span class="mono text-xs text-[var(--color-text-dim)] block mt-0.5">{a.readingTime} min läsning</span>
              </div>
            </a>
          </li>
        ))}
      </ol>
    </section>
  </section>
</BaseLayout>
